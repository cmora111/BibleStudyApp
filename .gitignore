# =========================
# 🔥 CORE RULE: NO DATASETS
# =========================

# Downloaded / generated datasets
output/downloads/
output/tmp/
data/raw/
data/bundles/
data/tmp/

# SQLite / database files (local only)
*.db
*.sqlite
*.sqlite3

# =========================
# 🗺️ MAP + EXPORT OUTPUTS
# =========================

# Generated maps
*.html
exports/
map_exports/

# Knowledge graph exports
*.html
knowledge_graph.html

# =========================
# ⚡ CACHE + PERFORMANCE
# =========================

cache/
*.npz
*.jsonl

# Semantic embeddings cache
*embeddings*.npz
*embeddings*.json

# =========================
# 📦 LARGE FILE TYPES
# =========================

*.zip
*.tar
*.tar.gz
*.7z
*.rar
*.bin

# PDFs (like ESV source)
*.pdf

# =========================
# 🧠 MODEL / ML ARTIFACTS
# =========================

models/
*.pt
*.pth
*.onnx

# =========================
# 🐍 PYTHON
# =========================

__pycache__/
*.pyc
*.pyo
*.pyd

.venv/
venv/
env/

# =========================
# 🧪 DEV / DEBUG
# =========================

*.log
*.tmp
*.bak

# =========================
# 🧰 IDE / OS
